# --- HealthMonitor MVP - copy to .env and set values ---

# Database (PostgreSQL 16 + PostGIS). For Docker: postgresql://healthmonitor:healthmonitor@postgres:5432/healthmonitor
DATABASE_URL=postgresql://healthmonitor:healthmonitor@localhost:5432/healthmonitor

# Redis (broker + cache). For Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# AI & Translation (Phase 2+; leave empty for Phase 1)
OPENAI_API_KEY=
DEEPL_API_KEY=

# Optional: error monitoring
SENTRY_DSN=

# Frontend dev proxy target (optional)
VITE_API_BASE_URL=http://localhost:8000
